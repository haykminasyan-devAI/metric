# ── LiveKit (Self-Hosted) ──────────────────────────────────────────────────────
# URL of your LiveKit server (use ws:// for local, wss:// for production)
LIVEKIT_URL=ws://localhost:7880

# API key and secret generated when you set up your LiveKit server
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Used for: Whisper (STT) + TTS (always required)
# Also used as LLM when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── NVIDIA (optional) ─────────────────────────────────────────────────────────
# Required only when LLM_PROVIDER=nvidia (default)
NVIDIA_API_KEY=nvapi-your-nvidia-api-key-here

# ── LLM Selection ─────────────────────────────────────────────────────────────
# Provider: "nvidia" (default) or "openai"
LLM_PROVIDER=nvidia

# Model override (leave empty for default):
#   nvidia default: qwen/qwen3-next-80b-a3b-instruct
#   openai default: gpt-4o-mini
LLM_MODEL=

# ── Embedding Model Selection ──────────────────────────────────────────────────
# Default dense model (requested baseline).
EMBEDDING_MODEL=Metric-AI/armenian-text-embeddings-1

# ── Retrieval Re-ranker (not used in dense-only mode) ─────────────────────────
RERANKER_ENABLED=0

# Default multilingual reranker model.
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Number of fused candidates passed to reranker before final top-k selection.
RERANKER_CANDIDATES=30
